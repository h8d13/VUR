# Maintainer: Eihdran Lego <hadean-eon-dev@proton.me>

pkgname=apc-git
pkgver=r62.g59a44b7
pkgrel=1
pkgdesc="Lightweight bash wrapper for Pacman."
arch=('any')
_repo="h8d13/apc"
url="https://github.com/${_repo}"

license=('0BSD')
depends=('pacman' 'pacman-contrib' 'reflector')
provides=('apc')
conflicts=('apc')
source=("$pkgname::git+$url.git")
sha256sums=('SKIP')

pkgver() {
	cd "${srcdir}/${pkgname}"
	# always use git hash for version
	printf 'r%s.g%s' "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

package() {
	cd "${srcdir}/${pkgname}"
	install -Dm755 apc "${pkgdir}/usr/bin/apc"
	sed -i "s/^_ver_string=.*/_ver_string=\"${pkgver}\"/" "${pkgdir}/usr/bin/apc"
}
