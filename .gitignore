# --- makepkg build artifacts (any recipe dir, any depth) ---
pkg/
src/
*.pkg.tar.*
*.src.tar.*
*.log

# --- recipe-only policy ---
# Under pkgs/, commit ONLY packaging files. Everything else — source code
# (.sh .py .rs .c .go ...), tests, downloaded tarballs — is ignored no
# matter what. Allowlist, so a new language/extension can never sneak in.
# (!pkgs/**/ lets git descend into dirs to find the allowed files.)
pkgs/**
!pkgs/**/
# ...but never descend back into makepkg build dirs (!pkgs/**/ re-included them).
# Without this, an embedded VCS checkout under src/ leaks in as a git submodule.
pkgs/**/pkg/
pkgs/**/src/
!pkgs/**/.directory
!pkgs/**/PKGBUILD
!pkgs/**/.SRCINFO
!pkgs/**/.gitignore
!pkgs/**/.nvchecker.toml
!pkgs/**/*.patch
!pkgs/**/*.diff
!pkgs/**/*.hook
!pkgs/**/*.service
!pkgs/**/*.sysusers
!pkgs/**/*.tmpfiles
!pkgs/**/*.desktop
!pkgs/**/*.asc
# .install scriptlets only in -sys recipe dirs (the suffix that opts in).
!pkgs/*-sys/*.install

# --- editor / OS noise ---
*.swp
*~
.DS_Store
